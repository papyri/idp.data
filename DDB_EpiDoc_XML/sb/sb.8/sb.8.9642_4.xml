         <head n="8735" xml:lang="en">
            <date>AD 104?</date>
            <placeName>Tebtynis</placeName>
         </head>
         <div xml:lang="grc" type="edition" xml:space="preserve">
<ab>
    <lb n="1"/><supplied reason="lost">ἔτους </supplied><gap reason="lost" extent="unknown" unit="character"/><supplied reason="lost"> Αὐτοκράτορος Καί</supplied>σαρος Τραιανοῦ Ἁδριανοῦ Σεβαστοῦ μηνὸς Ἀπελλαίου <num value="15">ιε</num> Φαῶφι <num value="15">ιε</num> ἐν Τεβτύνι τῆς <expan>Πολ<ex>έμωνος</ex></expan> 

    <lb n="2"/><supplied reason="lost">μερίδος τοῦ Ἀρσινοίτου νομοῦ. ὁμολογεῖ </supplied><gap reason="lost" extent="unknown" unit="character"/><supplied reason="lost"> πρε</supplied>σβύτερος Διδᾶ τοῦ Διδύμου μητρὸς Διοσκοροῦτος τῆς Μοσχίωνος τῶν ἀπὸ τῆς μητροπόλεως 

    <lb n="3"/><gap reason="lost" extent="unknown" unit="character"/> <supplied reason="lost">ὡς ἐτῶν</supplied> <num value="50"><supplied reason="lost">πεν</supplied>τήκοντα</num> οὐλὴ <choice><reg>χείλει</reg><orig>χείλι</orig></choice> τῷ ἄνω ἐξ ἀριστερῶν συνκεχωρηκέναι μετὰ τὴν ἑαυτοῦ τελευτὴν εἶναι <choice><reg>τοῖς</reg><orig>τῶν</orig></choice> 

    <lb n="4"/><supplied reason="lost">γεγονόσι αὐτῷ ἐκ τῆς ἑαυτοῦ γυναικὸς Κλ</supplied>εοπάτρας τῆς Διονυσίου υἱοῖς <num value="2">δυσὶ</num> Ἀμμωνίῳ καὶ Ἡρακλείδῃ ἑκάστῳ ἐξ ἴσου τὴν ὑπάρχουσαν αὐτῷ περὶ 

    <lb n="5"/><app type="editorial"><lem resp="BL 7.213"><gap reason="lost" extent="unknown" unit="character"/>ωνίου</lem><rdg><gap reason="lost" extent="unknown" unit="character"/>μύκου</rdg></app> τοῦ καὶ Ἀρείου Ἀρχιστρατείου τοῦ καὶ Ἀλθαιέως ἀμπελῶνος ἑκτολογουμένου ἄρουραν 

    <lb n="6"/><num value="1"><supplied reason="lost">μίαν</supplied></num> <supplied reason="lost">καὶ τὸ ὕπαρχον αὐτῷ ἥμισυ μέρος κοινὸν</supplied> καὶ ἀδιαίρετον πρὸς τὸν ἀδελφὸν αὐτοῦ Μοσχίωνα οἰκίας καὶ αὐλῆς καὶ ὅσα ἐὰν ἄλλα <choice><reg>καταλείψει</reg><orig>καταλ<unclear>ίψ</unclear>ει</orig></choice> 

    <lb n="7"/><gap reason="lost" extent="unknown" unit="character"/><supplied reason="lost"> ἢ καὶ ἕτερα σὺν τοῖς ἄλλοις ἐλευ</supplied>σομένοις εἰς αὐτὸν ἀφʼ οὗ δήποτε οὖν τρόπου, ἔτι δὲ καὶ τὰ ὑπʼ αὐτοῦ ἀπολειφθησόμενα ἐπί

    <lb n="8" break="no"/><supplied reason="lost">πλοα </supplied><gap reason="lost" extent="unknown" unit="character"/><supplied reason="lost"> καὶ ἐνδομε</supplied>νία καὶ <choice><reg>ἐνοφειλόμενα</reg><orig>ἐνοφιλόμενα</orig></choice> αὐτῷ καθʼ ὃν δήποτε οὖν τρόπον. ἡ δὲ προγεγραμμένη αὐτῶν μή

    <lb n="9" break="no"/><supplied reason="lost">τηρ Κλεοπάτρα </supplied><gap reason="lost" extent="unknown" unit="character"/> ἀφʼ οὗ ἐὰν ἔτους τελευτήσῃ ἐφʼ ὃν χρόνον περίεστιν καὶ ἄγαμος καθέστηκεν τὰ προ

    <lb n="10" break="no"/><gap reason="lost" extent="unknown" unit="character"/><supplied reason="lost"> ἐ</supplied>νοικεῖν ἐν τοῖς οἰκοπέδοις καὶ δουλεύεσθαι ὑφʼ ὧν ἐὰν <choice><reg>καταλείψει</reg><orig>καταλίψει</orig></choice> δουλικῶν σωμάτων 

    <lb n="11"/><gap reason="lost" extent="unknown" unit="character"/><gap reason="illegible" quantity="1" unit="character"/> αὐτὴν Κλεοπάτραν τρεφούσης αὐτῆς καὶ ἱματιζούσης τὰ αὐτὰ ἐξ ἀλλήλων τέκνα <gap reason="illegible" quantity="4" unit="character"/> 

    <lb n="12"/><gap reason="lost" extent="unknown" unit="character"/> τοῖς αὐτοῖς τέκνοις ἐξουσίας μηδὲν ἐπὶ καταχρηματισμὸν οἰκονομῆσαι κατὰ τῶν <gap reason="illegible" quantity="4" unit="character"/> 

    <lb n="13"/><gap reason="lost" extent="unknown" unit="character"/> τῆς μητρὸς αὐτῶν πρὸς τὸ μένειν <unclear>αὐ</unclear><supplied reason="lost">τῇ τὴ</supplied>ν καρπείαν καὶ ἐνοίκησιν καὶ δουλείαν 

    <lb n="14"/><gap reason="lost" extent="unknown" unit="character"/><supplied reason="lost"> το</supplied>ῦ σώματος αὐτοῦ κηδείαν εἰσ<unclear>εν</unclear><supplied reason="lost">ενκέτ</supplied>ωσαν ἀργυρίου δραχμὰς <num value="200">διακ<supplied reason="lost">οσίας</supplied></num> 

    <lb n="15"/><gap reason="lost" extent="unknown" unit="character"/><supplied reason="lost"> τὸ</supplied> σῶμα αὐτοῦ ἐν τοῖς <app type="editorial"><lem resp="BL 7.123">περὶ τὸν Λαβύρ<supplied reason="lost">ι</supplied><unclear>ν</unclear>θ<supplied reason="lost">ον</supplied> <unclear>τόπ</unclear>οις</lem><rdg>περὶ Λαβύρ<supplied reason="lost">ι</supplied><unclear>νθ</unclear><supplied reason="lost">ον </supplied><gap reason="lost" quantity="3" unit="character"/>οις</rdg></app> αὐτῷ. ἀκυρῶν <app type="editorial"><lem resp="BL 8.353">ὄντων</lem><rdg>ὁ προγε

    <lb n="16" break="no"/><supplied reason="lost">γραμμένος </supplied></rdg></app> <lb n="16"/><gap reason="lost" extent="unknown" unit="character"/> κατὰ πάντα τρόπον, τοῦτο δὲ τὸ συνχώρημα κύριον εἶναι σὺν τοῖς διʼ αὐτοῦ <app type="editorial"><lem resp="BL 8.353"><choice><reg>ἐγγεγραμμένοις</reg><orig>ἐνγεγραμμένοις</orig></choice></lem><rdg>ἐγγεγρ<supplied reason="lost">αμ</supplied>

    <lb n="17" break="no"/><supplied reason="lost">μένοις</supplied></rdg></app> <lb n="17"/><supplied reason="lost">ἐφʼ ὃν δὲ χρόνον περίεστιν ὁ ὁμολογῶν ἔχειν αὐ</supplied><unclear>τὸ</unclear>ν κατὰ τῶν ἑαυτοῦ <unclear>ὑπαρχ</unclear><supplied reason="lost">όντων</supplied> <unclear>ὁλ</unclear><supplied reason="lost">οσχερῆ ἐξου</supplied>σίαν πωλεῖν ὑποτίθεσθαι μεταδιατίθεσθαι 

    <lb n="18"/><gap reason="lost" extent="unknown" unit="character"/>ς ἄλλῳ δὲ οὐδενὶ οὐδενὸς ὑπ<supplied reason="lost">ο</supplied>χωρῶ. μάρτυρες Ἡρακλείδης ὁ καὶ <app type="editorial"><lem resp="BL 7.213">Γέμ<unclear>ελ</unclear>λος Ἡρακλείδου <expan>ὡ<ex>ς</ex></expan> <expan><ex>ἐτῶν</ex></expan></lem><rdg><gap reason="illegible" quantity="4" unit="character"/><unclear>στο</unclear>λος Ἡρακλείδου <gap reason="illegible" quantity="3" unit="character"/></rdg></app> 

    <lb n="19"/><gap reason="lost" extent="unknown" unit="character"/>ων οὐλὴ ὀφρύι δεξιᾷ, Δίδυμος Ὠριγένους τῶν <expan>κεκοσμητευκότ<ex>ων</ex></expan> ὡς ἐτῶν <num value="45">τεσσαράκοντα πέν

    <lb n="20" break="no"/><supplied reason="lost">τε</supplied></num> <gap reason="lost" extent="unknown" unit="character"/><supplied reason="lost"> Σάτυρος ὁ καὶ Ὡρίων <app type="editorial"><lem resp="cf. BL 8.353">Μαρίωνος</lem><rdg>Λαβήσιος</rdg></app> ὡς <expan><ex>ἐτῶν</ex></expan></supplied> <num value="30">τριάκοντα</num> οὐλὴ ὀφρύι ἀριστερᾷ, Μυσθῆς Διδύμου ὡς ἐτῶν τριάκοντα  

    <lb n="21"/><gap reason="lost" extent="unknown" unit="character"/><supplied reason="lost"> Σ</supplied>αβεῖνος Ἀπολλωνίου τοῦ καὶ Ἰσιδώρου ὡς ἐτῶν <num value="50">πεντή<unclear>κον</unclear>

    <lb n="22" break="no"/><supplied reason="lost">τα</supplied></num> <gap reason="lost" extent="unknown" unit="character"/><supplied reason="lost"> Διόσκορος Ῥ</supplied>ούφου ὡς ἐτῶν <num value="38">τριάκοντα ὀκτὼ</num> <choice><reg>οὐλὴ</reg><orig>οὐληι</orig></choice> ποδὶ δεξιῶι, οἱ <num value="6">ἓξ</num> 

    <lb n="23"/> <gap reason="lost" extent="unknown" unit="character"/><supplied reason="lost"> <handShift new="m2"/> </supplied><gap reason="lost" extent="unknown" unit="character"/><supplied reason="lost"> συνεχ</supplied>ώρησα μετὰ τὴν τελευτήν μου τοῖς υἱοῖς μου Ἀμμωνίωι καὶ 

    <lb n="24"/><supplied reason="lost">Ἡρακλείδῃ </supplied><gap reason="lost" extent="unknown" unit="character"/><supplied reason="lost"> ἄρ</supplied>ουραν <num value="1">μίαν</num> καὶ τὸ ἥμισυ μέρος τῆς οἰκίας καὶ αὐλῆς καὶ ὅσα ἐὰν 

    <lb n="25"/><supplied reason="lost">καταλείψω </supplied><gap reason="lost" extent="unknown" unit="character"/>ου ἢ καὶ <app type="editorial"><lem resp="BL 8.353">ἑτέρων</lem><rdg>ἕτερα</rdg></app> σὺν τ<unclear>οῖς</unclear> <unclear>ἄλλ</unclear>οις ἐλευσομένοις εἴς με ἀφʼ οὗ δήποτε οὗν 

    <lb n="26"/><supplied reason="lost">τρόπου </supplied><gap reason="lost" extent="unknown" unit="character"/> καὶ τὰ <unclear>ἐνο</unclear>φει<unclear>λ</unclear>όμε<unclear>να</unclear> καὶ γενήματα, τῆς γυναικός μου Κλεοπάτρας 

    <lb n="27"/><gap reason="lost" extent="unknown" unit="character"/> καὶ ἐνοικούσης καὶ δουλευομένης, τρεφούσης καὶ ἱματιζούσης 

    <lb n="28"/><gap reason="lost" extent="unknown" unit="character"/>ς καὶ συνεπείσθη ἅπασι καθὼς πρόκιται καὶ σφραγιῶι γλύμματι 

    <lb n="29"/> <gap reason="lost" extent="unknown" unit="character"/><supplied reason="lost"> <handShift new="m3"/> </supplied><app type="editorial"><lem resp="BL 8.353"><gap reason="lost" extent="unknown" unit="character"/> <supplied reason="lost">Ἡρακλεί</supplied>δου τοῦ <expan>κ<ex>αὶ</ex></expan></lem><rdg resp="BL 7.213"><gap reason="lost" extent="unknown" unit="character"/> <choice><reg>Ἡρακλεί<supplied reason="lost">δης</supplied></reg><orig><supplied reason="lost">Ἡρακλεί</supplied>δου</orig></choice> <choice><reg><expan>ἐπικ<ex>αλούμενος</ex></expan></reg><orig><expan>ἐπικ<ex>αλουμένου</ex></expan></orig></choice></rdg><rdg><gap reason="lost" extent="unknown" unit="character"/><abbr>δου<gap reason="illegible" quantity="2" unit="character"/>ακ</abbr></rdg></app> Λουρίου τοῦ Ἡρακλείδου μαρτυρῶ καὶ <choice><reg>σφραγιῶ</reg><orig>σφραγειῶ</orig></choice> <handShift new="m4"/> Δίδυ

    <lb n="30" break="no"/><supplied reason="lost">μος Ὡριγένους τῶν κεκοσμητευκότων </supplied><choice><reg><supplied reason="lost">μαρτυρῶ</supplied></reg><orig><supplied reason="lost">μαρτυρῶ</supplied>ι</orig></choice> καὶ <choice><reg>σφραγιῶ</reg><orig>σφραγιῶι</orig></choice>. <handShift new="m5"/> Σάτυρος ὁ <expan><unclear>κ</unclear><ex>αὶ</ex></expan> Ὡρίων 
<app type="editorial"><lem resp="BL 8.353"><expan>Μαρίω<ex>νος</ex></expan></lem><rdg><expan>Λαβ<unclear>ή</unclear><ex>σιος</ex></expan></rdg></app> μαρτυρῶ καὶ σφραγιῶ. <handShift new="m6"/> Μυσθῆς <choice><reg>Δι<supplied reason="omitted">δύμ</supplied>ου</reg><orig>Διου</orig></choice> <choice><reg>μαρτυρῶ</reg><orig>μαρτυρῶι</orig></choice> 

    <lb n="31"/><supplied reason="lost">καὶ σφραγιῶ. <handShift new="m7"/> Σαβεῖνος Ἀπολλωνίου τοῦ καὶ Ἰσιδ</supplied>ωρου μαρτυρῶ καὶ σφραγιῶ. <handShift new="m8"/> Διόσκορος Ῥούφου μαρτυρῶ καὶ <supplied reason="lost">σφραγιῶ</supplied>. 
</ab></div>
