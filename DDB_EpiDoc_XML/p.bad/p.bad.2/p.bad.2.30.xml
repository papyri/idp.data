    <lb n="5"/><gap reason="lost" quantity="8" unit="character"/><gap reason="illegible" quantity="4" unit="character"/><gap reason="illegible" quantity="1" unit="character"/> <supplied reason="lost">Δ</supplied>ιοδώρου καὶ <app type="editorial"><lem>Κύρας καὶ Ἄμα Λεὲτ</lem><rdg resp="BL 8.15">Κύρας καὶ Ἀμαλεὲτ</rdg><rdg>κύρας Καμαλεὲτ</rdg></app> 

    <lb n="6"/><supplied reason="lost">ἀπὸ τῆς Ἑρ</supplied>μουπολιτῶν <expan>π<ex>αρὰ</ex></expan> Αὐρηλίου Βίκτορος 

    <lb n="7"/><gap reason="lost" quantity="7" unit="character"/><supplied reason="lost"> μ</supplied>ητρὸς Σεκουντίλλας ἀπὸ τῆς αὐτῆς 

