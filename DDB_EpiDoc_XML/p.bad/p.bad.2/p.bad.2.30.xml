    <lb n="13" break="no"/><supplied reason="lost">ένου </supplied><gap reason="lost" quantity="6" unit="character"/>ς καὶ τοῦ ὁλοκλ<unclear>ήρ</unclear>ου δώματ<supplied reason="lost">ος</supplied> καὶ τοῦ 

    <lb n="14"/><supplied reason="lost">προσόντος φ</supplied><unclear>ρ</unclear>έατος καὶ τῆς αὐλῆς καὶ παντὸς δικ<unclear>α</unclear><supplied reason="lost">ί</supplied>ου 

