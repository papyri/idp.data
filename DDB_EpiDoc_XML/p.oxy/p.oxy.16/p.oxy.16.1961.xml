         <head n="22062" xml:lang="en">
            <date>AD 487</date>
            <placeName>Oxyrhynchus</placeName>
         </head>
         <div type="commentary" subtype="frontmatter" xml:space="preserve"><p>Lines 22–28 were not transcribed in the edition, which only quotes a part of lines 26–27. The missing text has been added on the basis of the original. (N. Gonis)</p></div>
         <div xml:lang="grc" type="edition" xml:space="preserve"><div n="r" type="textpart"><ab>

    <lb n="1" rend="indent"/> χμγ. 

    <lb n="2"/><g type="stauros"/> μετὰ τὴν ὑπατείαν Φλαου<hi rend="diaeresis">ί</hi>ου Λογ<g type="apostrophe"/>γίνου τοῦ <expan>λαμπρο<ex>τάτου</ex></expan> 

    <lb n="3" rend="indent"/> Φαρμοῦθι <num value="19">ιθ</num><g type="slanting-stroke"/><g type="slanting-stroke"/> <expan><hi rend="diaeresis">ἰ</hi>νδικ<ex>τίονος</ex></expan> <num value="10">ι</num>. 

    <lb n="4"/>Αὐρηλίοις <choice><reg><supplied reason="lost">Μ</supplied>αρτυρίῳ</reg><orig><supplied reason="lost">Μ</supplied>αρτυρίου</orig></choice> καὶ Ἀπφοῦτι ὁμογνησίοις 

    <lb n="5"/>ἀδελφοῖς ἐκ <supplied reason="lost">π</supplied>ατρὸς τοῦ τῆς <supplied reason="lost">μ</supplied>ακαρίας μνήμης 

    <lb n="6"/><unclear>Εὐλ</unclear><supplied reason="lost">ο</supplied>γίου γενομένου παλατίνου ἀπὸ τῆς λαμπρᾶς 

    <lb n="7"/>κ<supplied reason="lost">α</supplied>ὶ λαμπροτάτης Ὀξυρυγχιτῶν πόλεως 

    <lb n="8"/>Αὐρηλία Μαρ<supplied reason="lost">τυ</supplied>ρία θυγάτηρ Σαρμάτου ἀπὸ κώμης 

    <lb n="9"/><hi rend="diaeresis">Ἰ</hi>β<supplied reason="lost">ί</supplied>χεως το<supplied reason="lost">ῦ Ἡ</supplied>ρακλεοπολίτου νομοῦ χαίρειν. 

    <lb n="10"/>ἑκουσίως ἐπ<supplied reason="lost">ι</supplied>δέχομαι μισθώσασθαι ἔτι ἀπὸ νε

    <lb n="11" break="no"/>ομηνίας τοῦ παρόντος μηνὸς Φαρμοῦθι 

    <lb n="12"/>τοῦ ἐνεστῶτος ἔτους <num value="163">ρξγ</num> <num value="132">ρλβ</num> τῆς παρούσης 

    <lb n="13"/><num value="10">δεκάτης</num> <hi rend="diaeresis">ἰ</hi>ν<supplied reason="lost">δ</supplied>ικτίονος ἀπὸ τῶν ὑπαρχόντων τῇ 

    <lb n="14"/>ὑμῶν <choice><reg>εὐγενείᾳ</reg><orig>εὐγεν<unclear>ί</unclear>ᾳ</orig></choice> διακειμένων ἐν τῇ αὐτῇ πόλει 

    <lb n="15"/>ἐπʼ ἀμφόδου <choice><reg>Παμμένου<supplied reason="omitted">ς</supplied></reg><orig>Παμμένου</orig></choice> Παραδίσου ἀπὸ <choice><reg>οἰκίας</reg><orig>οἰκεί<unclear>ας</unclear></orig></choice> 

    <lb n="16"/><choice><reg>τόπον</reg><orig>τόπων</orig></choice> <num value="1">ἕνα</num> νεύοντα ἐπὶ νότον μετὰ παντὸς 

    <lb n="17"/>αὐτοῦ τοῦ δικαίου, καὶ τελέσω ὑπὲρ ἐνοικίου ἐνι

    <lb n="18" break="no"/>αυσίως ἀργυρίου μυριάδας <num value="1000"><choice><reg>χιλίας</reg><orig>χειλίας</orig></choice></num>, ὅπερ ἐνοίκιο<supplied reason="lost">ν</supplied> 

    <lb n="19"/>ἀπ<supplied reason="lost">ο</supplied>δώσω κατʼ ἔτος διʼ ἑξαμήνου τὸ ἥμισυ, καὶ ὁπη

    <lb n="20" break="no"/>νίκα δὲ ἂν βουληθείητε παραδώσω τὸν αὐ

    <lb n="21" break="no"/>τὸν <choice><reg>τόπον</reg><orig>τόκον</orig></choice> ἐπὶ νομῇ. κυρία ἡ μίσθωσις

    <lb n="22"/>ἁπλῆ γραφεῖσ<unclear>α</unclear> καὶ ἐπερωτηθεὶς ὡμολόγησα.
<milestone rend="paragraphos" unit="undefined"/>
    <lb n="23"/><handShift new="m2"/>Αὐρηλία Μαρτυρί<supplied reason="lost">α θ</supplied><unclear>υ</unclear>γάτηρ Σαρμάτου ἡ προκειμένη

    <lb n="24"/>πεποίη<unclear>μα</unclear>ι <unclear>τ</unclear><supplied reason="lost">ὴ</supplied><unclear>ν</unclear> μίσθωσιν καὶ ἀποδώσω

    <lb n="25"/><unclear>τὸ</unclear> <choice><reg>ἐνοίκιον</reg><orig>ἐν<unclear>οίκε</unclear>ιον</orig></choice> καὶ <choice><reg> συμφωνεῖ</reg><orig>συμφωνῖ</orig></choice> μοι πάντα τὰ

    <lb n="26"/>ἐγ<g type="apostrophe"/>γεγρ<unclear>α</unclear><supplied reason="lost">μ</supplied><unclear>μ</unclear>ένα ὡς πρόκειται. Αὐρήλιος Σερῆνος 

    <lb n="27"/>Φιλοξέν<unclear>ο</unclear><supplied reason="lost">υ</supplied> γενομένου διακόνου ἀξιωθεὶς ἔγραψ

    <lb n="28" break="no"/>α <hi rend="diaeresis">ὑ</hi>πὲρ αὐτῆς παρούσης γράμματα μὴ <choice><reg>εἰδυίης</reg><orig>εἰδυείης</orig></choice>.

    <lb n="29" rend="indent"/>  <g type="chirho"/> <foreign xml:lang="la">di emu Serenu</foreign><gap reason="illegible" quantity="3" unit="character"/> <foreign xml:lang="la">etelesthe</foreign> <expan><unclear>Φ</unclear><ex>αρμοῦθι</ex></expan> <foreign xml:lang="la">xviiii</foreign>  <expan><ex>ἰνδι</ex><unclear>κ</unclear><ex>τίονος</ex></expan> <foreign xml:lang="la">x. </foreign>
</ab></div><div n="v" type="textpart"><ab>

    <lb n="30"/><g type="stauros"/> <expan>μίσθ<ex>ωσις</ex></expan> Μαρτυρίας θυγατρὸ<supplied reason="lost">ς Σ</supplied>αρμάτου.</ab></div></div>
