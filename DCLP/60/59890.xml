<lb n="6"/><gap reason="lost" extent="unknown" unit="character"/><unclear>γ</unclear>ερων <app type="alternative"><lem><unclear>π</unclear>ι<unclear>μ</unclear></lem><rdg><unclear>π</unclear>ι<unclear>μ</unclear><supplied reason="lost">λ</supplied></rdg><rdg><unclear>π</unclear>ι<unclear>μ</unclear><supplied reason="lost">ρ</supplied></rdg></app><gap reason="lost" extent="unknown" unit="character"/></ab></div></div>
