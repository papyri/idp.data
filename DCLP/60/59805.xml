         <div xml:lang="grc" type="edition" xml:space="preserve"><ab><lb n="1"/></ab>
<div n="i" subtype="column" type="textpart">
<ab>
<lb n="1"/><supplied reason="lost">Πενθέα δʼ ἱδρ</supplied>ύσας ἐλατίνων ὄζων ἔπι,
<lb n="2"/><supplied reason="lost">ὀ</supplied>ρθὸν <app type="editorial"><lem resp="pap">μεθίεις</lem><rdg resp="mss">μεθίει</rdg></app> διὰ χερῶν βλάστημʼ ἄνω
<lb n="3"/>ἀτηρέμα, φυ<supplied reason="lost">λ</supplied><unclear>ά</unclear>σσων μὴ ἀναχαιτίσειέ νιν,
<lb n="4"/>ὀρ<unclear>θ</unclear>ὴ δʼ ἐς ὀρθὸν <choice><corr>αἰθέρʼ</corr><sic>αἰθέρα</sic></choice> ἐ<unclear>στηρίζετ</unclear>ο,
<lb n="5"/><unclear>ἔ</unclear>χουσα νώτ<unclear>οι</unclear>ς δεσπότην ἐφήμενον.
<lb n="5"/><choice><reg>ὤφθη</reg><orig>ὄφθη</orig></choice> δὲ μᾶλλον ἢ κατεῖδε μαινάδας. 
<lb n="6"/><unclear>ὅσο</unclear>ν γὰρ οὔπ<unclear>ω</unclear> δῆλος ἦν θά<unclear>σσ</unclear>ων ἄνω, 
<lb n="7"/><supplied reason="lost">καὶ τὸν</supplied> ξένον <unclear>μ</unclear>ὲν οὐκέτʼ εἰσορᾶν <unclear>πα</unclear>ρῆν, 
<lb n="8"/><supplied reason="lost">ἐκ δʼ αἰθ</supplied>έρος φωνή τις, ὡς <unclear>μὲν</unclear> <unclear>εἰ</unclear>κάσαι 
<lb n="9"/><supplied reason="lost">Διόνυσο</supplied>ς, ἀνεβόησεν· Ὦ νεάνιδες, 
<lb n="10"/><supplied reason="lost">ἄγω τὸν ὑ</supplied>μᾶς κἀμὲ τἀμά τε ὄργια 
<lb n="11"/><supplied reason="lost">γέλων τι</supplied>θέμενο<supplied reason="lost">ν· ἀ</supplied>λλὰ <app type="editorial"><lem resp="pap."><choice><reg>τιμωρεῖτ’</reg><orig>τειμωρεῖτ’</orig></choice> ἐμοὶ</lem><rdg resp="mss.">τιμωρεῖσθέ νιν</rdg></app>
<lb n="12"/><supplied reason="lost">καὶ τ</supplied><unclear>αῦθ</unclear>ʼ ἅμʼ ἠγό<unclear>ρευ</unclear><supplied reason="lost">ε</supplied> <unclear>καὶ</unclear> <unclear>π</unclear>ρὸς ο<unclear>ὐ</unclear>ρα<unclear>νὸ</unclear>ν 
<lb n="13"/><supplied reason="lost">καὶ γ</supplied><unclear>α</unclear>ῖαν ἐστήρι<supplied reason="lost">ξε</supplied> φ<unclear>ῶ</unclear><supplied reason="lost">ς</supplied> <subst><add place="inline">σεμνοῦ</add><del rend="corrected">σεμνὸν</del></subst> πυρός. 
<lb n="14"/><supplied reason="lost">σίγη</supplied>σε δʼ αἰθήρ, σῖ<supplied reason="lost">γα <gap reason="illegible" quantity="3" unit="character"/></supplied><del rend="erasure">π</del><unclear>νάπ</unclear>η 
<lb n="15"/><subst><add place="inline"><supplied reason="lost">φύλ</supplied><unclear>λ</unclear>ʼ</add><del rend="corrected"><supplied reason="lost">φύλ</supplied><unclear>λ</unclear>α</del></subst> εἶχε, θηρῶν <supplied reason="lost">δʼ οὐ</supplied>κ ἂν ἤκουσας <app type="editorial"><lem resp="pap.">Βρόμ<unclear>ο</unclear>ν</lem><rdg resp="mss.">βοήν</rdg></app> <g type="obelos"/>
<lb n="16"/><supplied reason="lost">αἳ δʼ</supplied> ὠσὶν ἠχὴν οὐ σαφῶς δεδεγμέναι 
<lb n="17"/><supplied reason="lost">ἔστ</supplied>ησαν ὀρθαὶ <supplied reason="lost">κα</supplied>ὶ <choice><reg>διήνεγκαν</reg><orig>δικήνεγκαν</orig></choice> <app type="editorial"><lem resp="pap."><supplied reason="lost">κ</supplied>άρα</lem><rdg resp="mss."><supplied reason="lost">κ</supplied>όρας</rdg></app> 
<lb n="18"/><supplied reason="lost">ὃ δʼ αὖ</supplied>θις ἐπεκέλευσεν· ὡς δʼ ἐγνώ<unclear>ρ</unclear>ισαν 
<lb n="19"/><supplied reason="lost">σαφῆ κε</supplied>λευσ<supplied reason="lost">μὸν Β</supplied>α<unclear>κ</unclear>χίου Κ<supplied reason="lost">άδμ</supplied>ου κόραι, 
<lb n="20"/><supplied reason="lost">ᾖξα</supplied>ν πελείας ὠκ<unclear>ύ</unclear>τητʼ οὐχ ἥ<supplied reason="lost">σσονε</supplied>ς 
<lb n="21"/><supplied reason="lost">πᾶσαί</supplied> τε βάκχαι· δ<supplied reason="lost">ιὰ</supplied> δὲ χ<supplied reason="lost">ειμάρρου νάπη</supplied>ς 
<lb n="22"/><supplied reason="lost">ἀγμ</supplied>ῶν <subst><add place="inline">τα</add><del rend="corrected">τʼ</del></subst> <app type="editorial"><lem resp="pap.">ἐπήδων</lem><rdg resp="mss.">πήδων</rdg></app> θεο<supplied reason="lost">ῦ πνοα</supplied><unclear>ῖ</unclear>σ<supplied reason="lost">ι</supplied><unclear>ν</unclear> ἐ<unclear>μ</unclear>μανεῖς. 
<lb n="23"/><supplied reason="lost">ὡς δʼ ε</supplied>ἶδον ἐλάτῃ δεσπότη<unclear>ν</unclear> ἐφήμενον, 
<lb n="24"/><supplied reason="lost">πρῶ</supplied>τον μὲν αὐτοῦ χερμάδας <choice><reg><unclear>κ</unclear>ραταιβόλους</reg><orig><unclear>κ</unclear>ρατιβόλους</orig></choice>
<lb n="25"/><supplied reason="lost">ἔρριπ</supplied>τον, ἀντίπ<supplied reason="lost">υρ</supplied><unclear>γ</unclear><supplied reason="lost">ο</supplied>ν ἐπ<supplied reason="lost">ιβ</supplied><unclear>ᾶσαι</unclear> <unclear>π</unclear>έτραν, 
<lb n="26"/><supplied reason="lost">ὄζοι</supplied>σί τʼ ἐλατίνοισιν ἠκοντίζετο. 
<lb n="27"/><supplied reason="lost">ἄλλαι</supplied> δὲ θύρσους ἵεσαν διʼ αἰθέρος 
<lb n="28"/><supplied reason="lost">Πενθ</supplied>έως, στόχον δύστηνον· ἀλλʼ οὐκ ἤνυτον. 
<lb n="29"/><supplied reason="lost">κρεῖσ</supplied>σον γὰρ ὕψος τῆς προθυμί<unclear>ας</unclear> ἔχων 
<lb n="30"/><supplied reason="lost">καθῆ</supplied>στο <app type="editorial"><lem resp="pap.">τλήμων</lem><rdg resp="mss.">τλῆμον</rdg></app>, ἀπορίᾳ λελημμένος. 
<lb n="31"/><supplied reason="lost">τέλο</supplied>ς δὲ δρυΐνους συγκεραυνοῦσαι κλάδους 
<lb n="32"/><supplied reason="lost">ῥίζας ἀ</supplied>νεσπάρασσον ἀσιδήρο<unclear>ι</unclear>ς μοχλοῖς.
</ab>
</div>
<div n="ii" subtype="column" type="textpart"> 
<ab>
<lb n="1"/>Βάκχαι τὰ Πενθέως<gap reason="lost" extent="unknown" unit="character"/>πι<gap reason="lost" extent="unknown" unit="character"/>τ<unclear>ω</unclear><gap reason="lost" extent="unknown" unit="character"/>
<lb n="2"/>ἐπεὶ δὲ μόχθων τ<supplied reason="lost">έρματʼ ο</supplied><unclear>ὐ</unclear>κ ἐξ<supplied reason="lost">ήνυτον,</supplied> 
<lb n="3"/>ἔλεξʼ Ἀγαύη· Φέρ<unclear>ε</unclear>, <supplied reason="lost">περι</supplied><unclear>στ</unclear>ᾶσαι κύ<unclear>κ</unclear><supplied reason="lost">λωι</supplied> 
<lb n="4"/>πτόρθου λάβεσ<unclear>θε</unclear>, <unclear>μ</unclear><supplied reason="lost">α</supplied><unclear>ι</unclear>ν<unclear>ά</unclear>δες, τὸ<unclear>ν</unclear> <supplied reason="lost">ἀμβάτην</supplied> 
<lb n="5"/><subst><add place="inline">θῆρʼ</add><del rend="corrected">θῆρα</del></subst> ὡς ἕλωμ<unclear>εν</unclear>, <unclear>μ</unclear>ηδʼ <supplied reason="lost">ἀπα</supplied>γγείληι <supplied reason="lost">θεοῦ</supplied> 
<lb n="6"/>χορ<supplied reason="lost">οὺς</supplied> κρ<supplied reason="lost">υ</supplied>φ<unclear>αί</unclear>ους. <supplied reason="lost">αἳ</supplied> δ<unclear>ὲ</unclear> <supplied reason="lost">μ</supplied>υρίαν χ<unclear>έ</unclear><supplied reason="lost">ρα</supplied> 
<lb n="7"/>προσέθεσαν ἐλάτηι κἀξανέσπασαν <supplied reason="lost">χθονός·</supplied>
<lb n="8"/>ὑψοῦ δὲ θάσσων ὑψόθ<supplied reason="lost">εν</supplied> χαμα<supplied reason="lost">ιριφὴς</supplied>
<lb n="9"/>πίπτει πρὸς οὖδας μυρίο<supplied reason="lost">ις</supplied> <choice><reg>οἰμώ<supplied reason="lost">γμασιν</supplied></reg><orig>ὠμώ<supplied reason="lost">γμασιν</supplied></orig></choice>
<lb n="10"/>Πενθεύς· κακοῦ δ’ ἄρ’ ἐγγὺς ὢν ἐμ<supplied reason="lost">άνθανεν.</supplied>
<lb n="11"/>πρώτη δὲ μή<supplied reason="lost">τ</supplied>ηρ ἦρξεν <choice><reg>ἱερέα</reg><orig>ἱερε<supplied reason="lost">ί</supplied>α</orig></choice> φό<supplied reason="lost">νου</supplied>
<lb n="12"/>καὶ <app type="editorial"><lem>προσπίτνει</lem><rdg>προσπί<unclear>πτ</unclear>ει</rdg></app> νιν· ὃ δὲ μίτραν κό<supplied reason="lost">μης ἄπο</supplied>
<lb n="13"/><unclear>ἔρρι</unclear>ψεν, ὥς ν<unclear>ι</unclear>ν γνωρίσασα μὴ κτά<unclear>ν</unclear><supplied reason="lost">οι</supplied>
<lb n="14"/>τλήμων <unclear>Ἀ</unclear>γα<unclear>ύ</unclear>η, καὶ λέγει, πα<unclear>ρ</unclear>ηίδος
<lb n="15"/>ψαύων· Ἐγώ τοι, μῆτερ, εἰμί, παῖς ο<gap reason="lost" extent="unknown" unit="character"/>
<lb n="16"/>Πενθ<unclear>ε</unclear>ύς, <unclear>ὃ</unclear>ν ἔτεκες ἐν δόμοις Ἐ<supplied reason="lost">χίονος·</supplied>
<lb n="17"/><choice><reg>ο<supplied reason="lost">ἴ</supplied>κτ<supplied reason="lost">ιρ</supplied>ε</reg><orig>ο<supplied reason="lost">ἴ</supplied><unclear>κτε</unclear><supplied reason="lost">ιρ</supplied>ε</orig></choice> δʼ ὦ μῆτέρ με, μη<unclear>δὲ</unclear> ταῖς ἐμ<supplied reason="lost">αῖς</supplied>
<lb n="18"/>ἁ<supplied reason="lost">μαρτίαι</supplied>σι παῖδα σὸν κατακτάνῃς.
<lb n="19"/>ἣ <supplied reason="lost">δʼ ἀφρὸ</supplied>ν ἐξιεῖσα καὶ διαστρόφους
<lb n="20"/><unclear>κό</unclear><supplied reason="lost">ρας</supplied> <choice><reg><supplied reason="lost">ἑ</supplied>λίσσουσʼ</reg><orig><supplied reason="lost">ἑ</supplied>λίσσουσα</orig></choice>, οὐ <choice><reg>φρονοῦσʼ</reg><orig>φρονοῦσα</orig></choice> ἃ χρὴ φ<supplied reason="lost">ρονεῖν,</supplied>
<lb n="21"/>ἐ<unclear>κ</unclear> <supplied reason="lost">Βακχ</supplied><unclear>ί</unclear>ου κατείχετʼ, οὐ<unclear>δ</unclear>ʼ <choice><reg>ἔπειθε</reg><orig>ἔπιθε</orig></choice> νιν.
<lb n="22"/>λαβοῦσα <supplied reason="lost">δʼ</supplied> <choice><corr>ὠλένης</corr><sic>ὠλέν<supplied reason="lost">α</supplied><unclear>ι</unclear>σ<unclear>ι</unclear></sic></choice> ἀριστε<unclear>ρὰν</unclear> χ<unclear>έρ</unclear>α,
<lb n="23"/><app type="editorial"><lem resp="pap.">πλευραῖσιν</lem><rdg resp="mss.">πλευροῖσιν</rdg></app> ἀντιβᾶσα τοῦ δ<unclear>υ</unclear><supplied reason="lost">σδαίμονος</supplied>
<lb n="24"/>ἀπεσπά<unclear>ρα</unclear>ξεν ὦμον, οὐχ ὑπὸ <supplied reason="lost">σθένους,</supplied>
<lb n="25"/>ἀλλʼ ὁ θεὸς εὐμάρειαν ἐπεδ<supplied reason="lost">ίδου χεροῖν·</supplied>
<lb n="26"/>Ἰνὼ δὲ τἀπὶ θάτερʼ ἐξειργάζε<supplied reason="lost">το,</supplied>
<lb n="27"/>ῥηγνῦσα σάρκας, Αὐτονόη τʼ ὄ<supplied reason="lost">χλος τε πᾶς</supplied>
<lb n="28"/>ἐπεῖχε βακχῶν· ἦν δὲ πᾶσα ὁμ<supplied reason="lost">οῦ βοή,</supplied>
<lb n="29"/>ὃ μὲν στενάζων ὅσον ἐτύγχ<supplied reason="lost">ανʼ ἐμπνέων,</supplied>
<lb n="30"/><choice><corr>αἳ</corr><sic>α</sic></choice> δʼ ἠλάλαζον. ἔφερε δʼ ἣ μὲν ὠ<supplied reason="lost">λένην,</supplied>
<lb n="31"/><choice><corr>ἣ</corr><sic>αι</sic></choice> δʼ ἴχνος αὐταῖς ἀρβύλαις· γυ<supplied reason="lost">μνοῦντο δὲ</supplied>
<lb n="32"/>πλευραὶ σπαραγμοῖς· πᾶσα δʼ <supplied reason="lost">ᾑματωμένη</supplied>
<lb n="33"/>χεῖρας <app type="editorial"><lem resp="pap.">διεσφ<unclear>α</unclear>ίριζε</lem><rdg resp="mss.">διεσφέριζε</rdg></app>σάρκα Πε<supplied reason="lost">νθέως.</supplied>
</ab>
